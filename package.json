{
  "name": "url-shortener",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "typecheck": "bun --cwd client typecheck && bun --cwd server typecheck",
    "lint": "biome check && bun --cwd client lint",
    "lint:fix": "biome check --write && bun --cwd client lint:fix",
    "dev": "concurrently -n client,server -c blue,green \"bun --cwd client dev\" \"bun --cwd server dev\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "concurrently": "^9.0.0"
  }
}
